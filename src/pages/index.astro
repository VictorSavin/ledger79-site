---
import { createClient } from "@supabase/supabase-js";

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const { data } = await supabase
  .from("site_content")
  .select("*")
  .eq("id", 1)
  .maybeSingle();

const content = data ?? {};



const tickerItems = [
  { symbol: "XAUUSD", price: "3348.20", change: "+0.42%" },
  { symbol: "EURUSD", price: "1.0834", change: "+0.11%" },
  { symbol: "GBPUSD", price: "1.2748", change: "-0.08%" },
  { symbol: "USDJPY", price: "154.21", change: "+0.19%" },
  { symbol: "GBPJPY", price: "196.42", change: "+0.24%" },
  { symbol: "DXY", price: "104.82", change: "-0.14%" },
  { symbol: "USOIL", price: "81.14", change: "+0.27%" },
  { symbol: "BTCUSD", price: "84750", change: "+1.12%" }
];

const { data: weeklyRecords } = await supabase
  .from("weekly_records")
  .select("*")
  .order("published_at", { ascending: false });

const allWeeklyRecords = weeklyRecords ?? [];
const recentResults = allWeeklyRecords.slice(0, 3);

const stats = [
  { label: "Weeks Posted", value: String(allWeeklyRecords.length) },
  {
    label: "Wins",
    value: String(allWeeklyRecords.filter((item) => item.result_status === "Won").length)
  },
  {
    label: "Losses",
    value: String(allWeeklyRecords.filter((item) => item.result_status === "Lost").length)
  },
  {
    label: "Invalidated",
    value: String(allWeeklyRecords.filter((item) => item.result_status === "Invalidated").length)
  }
];


const signalCards = [
  { label: "Neutral Zone", value: content.neutral_zone ?? "Pending" },
  { label: "Cycle 1", value: content.cycle_1 ?? "Pending" },
  { label: "Buy Trigger", value: content.buy_setup ?? "Pending" },
  { label: "Sell Trigger", value: content.sell_setup ?? "Pending" },
  { label: "Status", value: content.status ?? "Pending" }
];
