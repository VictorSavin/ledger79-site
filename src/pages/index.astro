<script>
  function updateClockAndMarketStatus() {
    const now = new Date();

    const utcHours = now.getUTCHours();
    const utcMinutes = now.getUTCMinutes();
    const utcSeconds = now.getUTCSeconds();
    const utcDay = now.getUTCDay();

    const pad = (num) => String(num).padStart(2, "0");

    const clockEl = document.getElementById("gmt-clock");
    const statusEl = document.getElementById("market-status");

    if (clockEl) {
      clockEl.textContent = `GMT ${pad(utcHours)}:${pad(utcMinutes)}:${pad(utcSeconds)}`;
    }

    let isOpen = false;

    if (utcDay >= 1 && utcDay <= 5) {
      isOpen = true;
    } else if (utcDay === 0 && utcHours >= 23) {
      isOpen = true;
    } else {
      isOpen = false;
    }

    if (statusEl) {
      statusEl.classList.remove("open", "closed");

      if (isOpen) {
        statusEl.classList.add("open");
        statusEl.innerHTML = `<span class="market-dot"></span>Market Open`;
      } else {
        statusEl.classList.add("closed");
        statusEl.innerHTML = `<span class="market-dot"></span>Market Closed`;
      }
    }
  }

  updateClockAndMarketStatus();
  setInterval(updateClockAndMarketStatus, 1000);
</script>

